# Maps provider: google | osm (default: osm — no billing required)
NEXT_PUBLIC_MAPS_PROVIDER=osm
MAPS_PROVIDER=osm

# Google Maps (only when MAPS_PROVIDER=google)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_API_KEY=

# Contact User-Agent sent with OSM geocoding requests (Photon)
NOMINATIM_USER_AGENT=limo-booking-demo/1.0 (your-email@example.com)
PHOTON_BASE_URL=https://photon.komoot.io
OSRM_BASE_URL=https://router.project-osrm.org

# PostgreSQL connection
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/limo_booking?schema=public
